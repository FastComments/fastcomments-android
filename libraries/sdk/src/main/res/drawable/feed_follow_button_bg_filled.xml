<?xml version="1.0" encoding="utf-8"?>
<!--
  "Follow" (filled) state of the feed follow button. Both fill and stroke are
  white so that View#setBackgroundTintList can recolor the entire pill with
  the current theme action color (a multiply tint reduces white -> tint color
  losslessly).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="14dp" />
    <solid android:color="@android:color/white" />
    <stroke
        android:width="1dp"
        android:color="@android:color/white" />
</shape>
