<?xml version="1.0" encoding="utf-8"?>
<!--
  Follow / unfollow pill rendered in feed post headers. <include>'d by every
  feed_post_item_*.xml variant.

  Hidden by default; FeedPostsAdapter only makes it visible when a
  FollowStateProvider has been registered with the SDK. The background
  drawable is applied at bind time so it can pick up the current theme
  action colour.

  Per-row layout_* attributes (margins, gravity) live on the <include> tag
  in each parent layout, not here. layout_width and layout_height are
  declared on the root only because Android requires them for inflation;
  they are overridden by the include tag at runtime.
-->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/followButton"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center"
    android:minHeight="48dp"
    android:minWidth="76dp"
    android:paddingHorizontal="14dp"
    android:paddingVertical="6dp"
    android:text="@string/follow"
    android:textAllCaps="false"
    android:textSize="12sp"
    android:textStyle="bold"
    android:visibility="gone"
    tools:visibility="visible" />
